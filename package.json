{
	"name": "kakao-rsu-tracker",
	"version": "1.0.0",
	"description": "카카오 RSU 실시간 자산 조회 및 동기부여 위젯",
	"main": "manifest.json",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"release": "standard-version",
		"release:minor": "standard-version --release-as minor",
		"release:major": "standard-version --release-as major",
		"release:patch": "standard-version --release-as patch",
		"postrelease": "node scripts/sync-manifest-version.js",
		"validate": "node -e \"console.log('Validating manifest.json...'); JSON.parse(require('fs').readFileSync('manifest.json', 'utf8')); console.log('✅ Valid!')\"",
		"test": "node tests/test_calculation.js",
		"clean": "rm -rf dist/",
		"package": "npm run build && zip -r kakao-rsu-tracker.zip * -x '*.git*' 'node_modules/*' 'tests/*' '*.md'"
	},
	"keywords": [
		"chrome-extension",
		"kakao",
		"rsu",
		"stock",
		"tracker",
		"finance"
	],
	"author": "mia.ow",
	"license": "MIT",
	"devDependencies": {
		"eslint": "^8.0.0",
		"prettier": "^3.0.0",
		"standard-version": "^9.5.0",
		"vite": "^6.3.5",
		"vite-plugin-web-extension": "4.4.4"
	},
	"engines": {
		"node": ">=16.0.0"
	}
}
