{
	"env": {
		"browser": true,
		"es6": true,
		"webextensions": true
	},
	"extends": ["eslint:recommended"],
	"parserOptions": {
		"ecmaVersion": 2022,
		"sourceType": "script"
	},
	"globals": {
		"chrome": "readonly"
	},
	"rules": {
		"no-console": "off",
		"no-unused-vars": "warn",
		"prefer-const": "error",
		"no-var": "error"
	}
} 